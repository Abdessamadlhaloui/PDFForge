# =============================================================================
# PDFForge — Backend Environment Variables
# =============================================================================
# Copy this file to .env and modify as needed:
#   cp .env.example .env
# =============================================================================

# --- Application -----------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TITLE=PDFForge API
APP_VERSION=1.0.0
DEBUG=true

# --- File Handling ----------------------------------------------------------
MAX_UPLOAD_SIZE_MB=100
TEMP_FILE_TTL_MINUTES=30
TEMP_DIR=/tmp/pdfforge

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Celery -----------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- CORS -------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Rate Limiting ----------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60

# --- External Tools ---------------------------------------------------------
GHOSTSCRIPT_PATH=gs
LIBREOFFICE_PATH=soffice
TESSERACT_PATH=tesseract

# --- AI Features (Phase 3) -------------------------------------------------
ENABLE_AI_FEATURES=false
AI_MODEL_NAME=facebook/bart-large-cnn
EMBEDDING_MODEL=all-MiniLM-L6-v2
AI_DEVICE=cpu
# Set to "cuda" if GPU available:
# AI_DEVICE=cuda

# --- Security ---------------------------------------------------------------
ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png,.tiff,.bmp,.webp
MAX_FILES_PER_REQUEST=20
